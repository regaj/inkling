# Inkling — example environment file.
# Copy to `.env` for local use. NEVER commit real secrets (see .gitignore).
#
# Code-signing / notarization credentials are read from the environment (or CI
# secrets) at release time only — they are never required to build or run the app
# locally, and must never be hardcoded.

# macOS notarization (release signing only)
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
# APPLE_SIGNING_IDENTITY=

# Windows code signing (release signing only)
# WINDOWS_CERTIFICATE=
# WINDOWS_CERTIFICATE_PASSWORD=

# Tauri updater signing (release only)
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
