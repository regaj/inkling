# Normalize line endings so Windows/macOS/Linux contributors don't churn.
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary assets — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.pdf  binary

# Generated / vendored — collapse in diffs and skip language stats
pnpm-lock.yaml       -diff linguist-generated
Cargo.lock           -diff linguist-generated
*.excalidraw         linguist-generated
